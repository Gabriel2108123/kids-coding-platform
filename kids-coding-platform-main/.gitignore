*.tsbuildinfo
.tsbuildinfo

# Temporary folders
tmp/
temp/
.cache/
.parcel-cache/

# Database
*.db
*.sqlite

# Package manager
package-lock.json
yarn.lock

# Performance and cache files
.eslintcache
.stylelintcache
.postcssrc
.babel_cache/
.webpack_cache/
.npm/
.yarn/
.pnp.*

# VS Code specific performance files
.vscode/settings.json.bak
.vscode/tasks.json.bak
.vscode/.ropeproject

# Editor backup files
*~
*.swp
*.swo
.#*
#*#

# Large log files that can slow down indexing
*.log.*
*.out
*.err

# Source maps (can be large)
*.map

# Storybook build outputs
storybook-static/
.storybook/build/

# Testing output
coverage/
.nyc_output/
test-results/
test-output/

# Documentation builds
docs/build/
docs/.docusaurus/

# Performance optimization - ignore large files that can be regenerated
**/*.tsbuildinfo
**/.cache
**/build
**/dist
**/.git
**/node_modules

# Empty or temporary files patterns
**/{
**/()
**/npm
**/totalLessons

# Documentation files that cause clutter
**/*_FIXES.md
**/*_STATUS.md
**/*_DOCUMENTATION.md
**/*_SUMMARY.md
**/*_GUIDE.md
**/IMPLEMENTATION_*.md
**/INTEGRATION_*.md
**/NETWORK_*.md
**/AUTH_*.md
**/MASCOT_*.md
**/TYPESCRIPT_*.md
**/ESLINT_*.md

# Test files (except actual working tests)
**/*.test.backup.*
**/*.spec.backup.*
**/*-test-*.js
**/*-test-*.ts
**/test-*.js
**/test-*.ts
