{
  "name": "bugsby-coding-world",
  "version": "1.0.0",
  "description": "Bugsby Coding World - Full Stack Development Environment for Kids",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "clean": "rimraf node_modules backend/node_modules frontend/node_modules backend/dist frontend/build",
    "reset": "npm run clean && npm run setup"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.7",
    "openai": "^5.9.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/body-parser": "^1.19.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^24.0.13",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.31.0",
    "rimraf": "^5.0.5",
    "typescript": "^4.9.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/kids-coding-platform.git"
  },
  "keywords": [
    "education",
    "coding",
    "kids",
    "programming",
    "learning",
    "coppa"
  ],
  "author": "Kids Coding Platform Team",
  "license": "MIT"
}
