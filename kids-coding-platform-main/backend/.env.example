# ==========================================
# KIDS CODING PLATFORM - BACKEND ENVIRONMENT
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/kids-coding-platform

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRES_IN=30d

# Password Hashing
BCRYPT_ROUNDS=12

# COPPA Compliance
COPPA_AGE_THRESHOLD=13
PARENTAL_CONSENT_REQUIRED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_COPPA_MAX_REQUESTS=50

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Email Configuration (for parental consent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@kidscoding.com

# External APIs
OPENAI_API_KEY=your-openai-api-key-here

# Security
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your-session-secret-key

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Content Moderation
CONTENT_MODERATION_ENABLED=true
AUTO_APPROVAL_THRESHOLD=0.8

# Development Tools
ENABLE_SWAGGER=true
ENABLE_MORGAN_LOGGING=true
