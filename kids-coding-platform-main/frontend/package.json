{
  "name": "bugsby-coding-world-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.10.0",
    "blockly": "^12.2.0",
    "classnames": "^2.5.1",
    "framer-motion": "^12.23.6",
    "phaser": "^3.90.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "^5.0.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--max-old-space-size=8192 --openssl-legacy-provider && react-scripts start",
    "start:fast": "set NODE_OPTIONS=--max-old-space-size=8192 --openssl-legacy-provider && set GENERATE_SOURCEMAP=false && react-scripts start",
    "start:production": "set NODE_OPTIONS=--max-old-space-size=8192 --openssl-legacy-provider && set NODE_ENV=production && react-scripts start",
    "build": "set NODE_OPTIONS=--max-old-space-size=8192 --openssl-legacy-provider && react-scripts build",
    "build:analyze": "set NODE_OPTIONS=--max-old-space-size=8192 --openssl-legacy-provider && npm run build && npx serve -s build",
    "test": "react-scripts test",
    "test:ci": "set CI=true && react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "clean": "rimraf build .cache node_modules/.cache",
    "clean:all": "rimraf build .cache node_modules && npm install",
    "optimize": "node ../scripts/optimize-environment.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.119",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7"
  }
}
