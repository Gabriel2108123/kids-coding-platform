# ==========================================
# KIDS CODING PLATFORM - FRONTEND ENVIRONMENT
# ==========================================

# Backend API Configuration
REACT_APP_API_BASE_URL=http://localhost:3001/api
REACT_APP_BACKEND_URL=http://localhost:3001

# Environment
REACT_APP_NODE_ENV=development

# Features
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_VOICE_COMMANDS=false

# External Services
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=

# Game/Editor Configuration
REACT_APP_MAX_PROJECT_SIZE=50000000
REACT_APP_SUPPORTED_FILE_TYPES=.png,.jpg,.jpeg,.gif,.mp3,.wav,.json
REACT_APP_BLOCKLY_MEDIA_PATH=/blockly/media/

# COPPA Compliance
REACT_APP_AGE_VERIFICATION_REQUIRED=true
REACT_APP_PARENTAL_CONSENT_REQUIRED=true

# Development
REACT_APP_DEBUG_MODE=true
REACT_APP_MOCK_DATA=false
